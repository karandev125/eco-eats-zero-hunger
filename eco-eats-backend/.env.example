MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/eco-eats?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Open/free geocoding and routing defaults.
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=eco-eats-zero-hunger-mvp/1.0
ROUTER_BASE_URL=https://router.project-osrm.org
ROUTE_EXPIRY_BUFFER_MINUTES=20
SENSOR_STALE_MINUTES=60
MAX_SENSOR_READINGS_PER_ITEM=50
MONGO_CONNECT_TIMEOUT_MS=10000

# Optional: set this to require x-device-token on /api/iot/telemetry.
IOT_DEVICE_TOKEN=
