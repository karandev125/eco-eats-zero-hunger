MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/eco-eats?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Open/free geocoding and routing defaults.
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=eco-eats-zero-hunger-mvp/1.0
ROUTER_BASE_URL=https://router.project-osrm.org
ROUTE_EXPIRY_BUFFER_MINUTES=20
SENSOR_STALE_MINUTES=60
MAX_SENSOR_READINGS_PER_ITEM=50
MONGO_CONNECT_TIMEOUT_MS=10000

# Optional: set this to require x-device-token on /api/iot/telemetry.
IOT_DEVICE_TOKEN=

# Google Sheets telemetry queue. The Sheet must contain:
# readingId, observedAt, deviceId, foodItemId, temperatureC, humidityPct, gasLevel, source
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_URL=
GOOGLE_SHEETS_PUBLIC_CSV_URL=
GOOGLE_SHEETS_PUBLIC_GID=0
GOOGLE_SHEETS_TELEMETRY_RANGE=Telemetry!A2:H
GOOGLE_SHEETS_HAS_HEADER=false
GOOGLE_SHEETS_DEFAULT_DEVICE_ID=eco-device-001
GOOGLE_SHEETS_IMPORT_MAX_ROWS=150
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEETS_SYNC_TOKEN=replace-with-a-long-random-sync-token
SHEETS_POLL_INTERVAL_MS=0
